    {
      "info": {
        "name": "Recruitment API",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Jobs records",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{{baseUrl}}/rcm/jobs/jobsV2",
            "headers": [
              {
                "name": "x-api-key",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "internalOnly",
                "value": "",
                "type": "query",
                "description": "Returns only Recruitment Jobs that are marked as Internal"
              }
            ]
          },
          "docs": "Retrieve Recruitment Job Records secured by Private API key\n"
        }
      ]
    },
    {
      "info": {
        "name": "User Details API v2",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get user detail(s) in Pulse",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "{{baseUrl}}/security/UserDetails",
            "headers": [
              {
                "name": "x-api-key",
                "value": ""
              }
            ],
            "params": [
              {
                "name": "email",
                "value": "",
                "type": "query",
                "description": "Email address"
              },
              {
                "name": "username",
                "value": "",
                "type": "query",
                "description": "Username"
              },
              {
                "name": "userId",
                "value": "",
                "type": "query",
                "description": "User Id"
              }
            ]
          },
          "docs": "Get user detail(s) in Pulse including their user additional attributes.\n- If no query parameters are provided, returns all users.\n- If `email`, `username`, or `userId` is provided, returns the matching user.\n**Authorised Roles:** *PulseSecurityUser*\n"
        },
        {
          "info": {
            "name": "Update user in Pulse",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "{{baseUrl}}/security/UserDetails",
            "headers": [
              {
                "name": "x-api-key",
                "value": ""
              }
            ]
          },
          "docs": "Update user in Pulse based on userId provided in request body\n\n**Authorised Roles:** *PulseSecurityUser*\n"
        },
        {
          "info": {
            "name": "Update user in Pulse",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "{{baseUrl}}/security/UserDetails",
            "headers": [
              {
                "name": "x-api-key",
                "value": ""
              }
            ]
          },
          "docs": "Update user in Pulse based on userId provided in request body\n\n**Authorised Roles:** *PulseSecurityUser*\n"
        },
        {
          "info": {
            "name": "Update user in Pulse",
            "type": "http"
          },
          "http": {
            "method": "PATCH",
            "url": "{{baseUrl}}/security/UserDetails",
            "headers": [
              {
                "name": "x-api-key",
                "value": ""
              }
            ]
          },
          "docs": "Update user in Pulse based on userId provided in request body\n\n**Authorised Roles:** *PulseSecurityUser*\n"
        }
      ]
    },
